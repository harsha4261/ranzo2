MONGODB_URL=mongodb://localhost:27017
DB_NAME=ranzo
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
OTP_TTL_SECONDS=60
OTP_VERIFICATION_WINDOW_SECONDS=300

# Comma-separated list of origins allowed to call this API with credentials.
# Must include the admin panel's real URL and the mobile app's dev/tunnel URL.
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8081,http://localhost:19006

# Leave both empty to keep wallet recharge disabled (503) until you have real keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
